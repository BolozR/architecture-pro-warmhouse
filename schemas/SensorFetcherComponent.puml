@startuml
title WarmHouse Sensor Fetcher Component Diagram

top to bottom direction

!include templates/C4_Component.puml

Container(apiGateway, "Api Gateway", "Java, Spring", "Routes requests for current temperature data")
System_Ext(temperatureSensor, "Temperature Sensor", "External API for getting current temperature")

Container_Boundary(sensorFetcher, "Sensor Fetcher") {
  Component(readingService, "Sensor Reading Service", "Java, Spring Service", "Manage current temperature requests")
  Component(sensorClient, "Temperature Sensor Client", "HTTP/Zigbee(или какой-то протокол умного дома) client", "Requests current temperature from the external sensor provider")
  Component(responseMapper, "Temperature Response Mapper", "Java component", "Normalizes provider responses for the API gateway")
}

Rel(apiGateway, readingService, "Requests temperature data")
Rel(readingService, sensorClient, "Fetches current temperature")
Rel(sensorClient, temperatureSensor, "Requests temperature reading")
Rel(sensorClient, responseMapper, "Passes provider response")

@enduml
