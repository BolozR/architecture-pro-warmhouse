@startuml
title WarmHouse Code Diagram

top to bottom direction
allowmixing

class ApiGateway {
  -db: PostgreSQL
  +getTemperature(sensorId: int)
  +switchHeating(deviceId: int, enabled: bool)
}

class HeatingWorker {
  -api: HeatingToggleAPI
  +enableHeating(deviceId: int)
  +disableHeating(deviceId: int)
}

class SensorFetcher {
  -api: TemperatureSensorAPI
  +getTemperature(sensorId: int)
}

class Device {
  +id: int
  +name: string
  +status: string
}

class Sensor {
  +id: int
  +location: string
  +value: float
}

class PostgreSQL {
  +saveDevice(device: Device)
  +getSensor(sensorId: int)
}

class HeatingToggleAPI {
  +turnOn(deviceId: int)
  +turnOff(deviceId: int)
}

class TemperatureSensorAPI {
  +read(sensorId: int)
}

ApiGateway --> HeatingWorker
ApiGateway --> SensorFetcher
ApiGateway --> PostgreSQL

HeatingWorker --> HeatingToggleAPI
SensorFetcher --> TemperatureSensorAPI

PostgreSQL --> Device
PostgreSQL --> Sensor

@enduml
