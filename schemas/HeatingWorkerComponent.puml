@startuml
title WarmHouse Heating Worker Component Diagram

top to bottom direction

!include templates/C4_Component.puml

Container(apiGateway, "Api Gateway", "Java, Spring", "Routes requests from the client application")
System_Ext(heatingToggle, "Heating Toggle", "External API for turning heating on and off")

Container_Boundary(heatingWorker, "Heating Worker") {
  Component(commandService, "Heating Command Service", "Java, Spring Service", "Validate heating commands and coordinate execution")
  Component(toggleClient, "Heating Toggle Client", "HTTP client", "Toggle external heating")
  Component(statusMapper, "Status Mapper", "Java component", "Map external responses to unified format")
}

Rel(apiGateway, commandService, "Sends heating commands")
Rel(commandService, toggleClient, "Invokes heating control requests")
Rel(toggleClient, heatingToggle, "Turns heating on/off")
Rel(toggleClient, statusMapper, "Passes external response")

@enduml
